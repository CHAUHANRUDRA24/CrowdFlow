# Environment Variables — CrowdFlow AI
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── AI / Gemini ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_google_gemini_key_here

# ── Firebase Admin SDK (server-side token verification) ────────────────────────
FIREBASE_PROJECT_ID=crowdflowai
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@crowdflowai.iam.gserviceaccount.com
# Paste the full private key from your service account JSON (escape newlines as \n)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Role-Based Access Control ──────────────────────────────────────────────────
# Comma-separated list of Google email addresses that should receive 'admin' role
ADMIN_EMAILS=you@example.com,ops@venue.com

# ── Server ─────────────────────────────────────────────────────────────────────
# Cloud Run sets PORT automatically. Only set this for local overrides.
PORT=3000
